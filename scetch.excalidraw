    {
      "id": "O5so05wjya7qoCIiBmci6",
      "type": "text",
      "x": 2520,
      "y": -500,
      "width": 653.839599609375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffa94d",
      "fillStyle": "solid",
