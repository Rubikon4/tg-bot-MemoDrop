    {
      "id": "Lh-FwvExGCBmibV4vOqON",
      "type": "text",
      "x": 200,
      "y": -160,
      "width": 641.57958984375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "9GIwsXAk9IiO8PtzDYezo"
      ],
      "frameId": null,
      "index": "b15V",
      "roundness": null,
      "seed": 1773069660,
      "version": 438,
      "versionNonce": 1555368728,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779834778475,
      "link": null,
      "locked": false,
      "text": "Первостепенно нужно понять что из себя будет представлять бот.\n1. Схема функциональности бота;\n\nДалее перейдем к выбору стека.\n2. Определить стек;\n\nИ наконец соберем архитектуру.\n3. Общая архитектура проекта.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Первостепенно нужно понять что из себя будет представлять бот.\n1. Схема функциональности бота;\n\nДалее перейдем к выбору стека.\n2. Определить стек;\n\nИ наконец соберем архитектуру.\n3. Общая архитектура проекта.",
      "autoResize": true,
      "lineHeight": 1.25
    },
