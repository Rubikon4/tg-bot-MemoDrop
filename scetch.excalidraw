    {
      "id": "Irrz4QOGls_-tH-tOfZ7o",
      "type": "text",
      "x": -60,
      "y": 740,
      "width": 503.2796630859375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
